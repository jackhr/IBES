APP_NAME="Ibes Car Rental"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.ibescarrental.com
APP_TIMEZONE=America/Antigua
# Set to true for local sqlite-backed development.
CLIENT_LOCAL_DEVELOPMENT=false
DB_SQLITE_PATH=database/database.sqlite

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=''

LOG_CHANNEL=stack
LOG_STACK=single
CACHE_STORE=file
SESSION_DRIVER=file

APP_DOMAIN=ibescarrental.com
APP_WWW_DOMAIN=www.ibescarrental.com

COMPANY_OWNER_FIRST=Irwin
COMPANY_OWNER_LAST=Philo
COMPANY_OWNER_FULL="Irwin Philo"
COMPANY_NAME="Ibes Car Rental"

SHOW_TESTIMONIALS=false

EMAIL_STRING=
CONTACT_EMAIL_STRING=
TESTING_EMAIL_STRING=
DEBUGGING_EMAIL_STRING=

DESTROY_SESSION_AFTER_ORDERING=true
UNDER_CONSTRUCTION=false
VISITOR_TRACKING_ENABLED=true

RATE_LIMIT_MAX=15
RATE_LIMIT_WINDOW=900
CONTACT_RATE_LIMIT_MAX=6
CONTACT_RATE_LIMIT_WINDOW=900
CONTACT_INFO_RATE_LIMIT_MAX=15
CONTACT_INFO_RATE_LIMIT_WINDOW=900
TAXI_RATE_LIMIT_MAX=6
TAXI_RATE_LIMIT_WINDOW=900
TAXI_REQUESTS_RATE_LIMIT_MAX=6
TAXI_REQUESTS_RATE_LIMIT_WINDOW=900
RESERVATION_RATE_LIMIT_MAX=8
RESERVATION_RATE_LIMIT_WINDOW=900
RESERVATION_API_RATE_LIMIT_MAX=60
RESERVATION_API_RATE_LIMIT_WINDOW=300
ORDER_REQUESTS_RATE_LIMIT_MAX=8
ORDER_REQUESTS_RATE_LIMIT_WINDOW=900

CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=hcaptcha
CAPTCHA_HTTP_TRANSPORT=stream
HCAPTCHA_SECRET_KEY=
HCAPTCHA_SITE_KEY=
HCAPTCHA_VERIFY_URL=https://api.hcaptcha.com/siteverify
RECAPTCHA_SECRET_KEY=
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

VITE_CAPTCHA_PROVIDER=hcaptcha
VITE_HCAPTCHA_SITE_KEY=
VITE_RECAPTCHA_SITE_KEY=
VITE_SITE_URL=https://www.ibescarrental.com
