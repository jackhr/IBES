# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php83” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

RewriteEngine On

# Force HTTPS and prepend www. to domain name
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\.
RewriteRule ^(.*)$ https://www.ibescarrental.com/$1 [R=301,L]

# Force known SPA routes to React entrypoint.
# This prevents stale legacy directories (e.g. /about/) from bypassing the SPA.
RewriteRule ^(about|faq|contact|reservation|taxi|confirmation)/?$ dist/index.html [L]

# Serve real files directly (PHP APIs, images, JS, CSS, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Route backend API requests through the PHP front controller.
RewriteRule ^api(?:/.*)?$ server/api.php [QSA,L]

# Don't rewrite explicit file-extension requests that do not exist.
# This keeps missing asset requests as real 404 responses.
RewriteCond %{REQUEST_URI} \.[a-z0-9]{1,8}$ [NC]
RewriteRule ^ - [L]

# SPA fallback: all route paths render the React app entrypoint.
RewriteRule ^ dist/index.html [L]
